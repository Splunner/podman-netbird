# .env
# Keycloak admin
KEYCLOAK_ADMIN=admin
# you can mofidy admin password is requried for init login for setting up custom admin user.
KEYCLOAK_ADMIN_PASSWORD=admini_init

# HTTP ENABLE
KC_HTTP_ENABLED=True

# Disable hostanme check
KC_HOSTNAME_STRICT=False

# reverse proxy
KC_PROXY_HEADERS=xforwarded
KC_HTTP_RELATIVE_PATH=/
# Database config
KC_DB=keycloak
KC_DB_URL_HOST=postgres-db
KC_DB_USERNAME=keycloak
# might be updated before start using it.
KC_DB_PASSWORD=----UpdatePassword

