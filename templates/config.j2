# Combined NetBird Server Configuration (Simplified)
# Generated by config_generations.py

server:
  listenAddress: ":80"
  exposedAddress: "https://{{ domnain_netbird }}:443"
  stunPorts:
    - 3478
  metricsPort: 9090
  healthcheckAddress: ":9000"
  logLevel: "info"
  logFile: "console"

  authSecret: "{{ random_key }}"  # 32-byte (256-bit) encryption key
  dataDir: "/var/lib/netbird"

{% if use_postgres_on_netbird %}
  authStore:
    engine: "postgres"
    dsn: "host={{ postgres_db_netbird.container_name }} user={{ postgres_db_netbird.postgres_db_username }} password={{ postgres_db_netbird.postgres_db_password }} dbname={{ postgres_db_netbird.netbird_auth_db_name }} sslmode=disable port={{ postgres_db_netbird.postgreS_db_port }}"

{% endif %}
  auth:
    issuer: "https://{{ domnain_netbird }}/oauth2"
    signKeyRefreshEnabled: true
    localAuthDisabled: false
    dashboardRedirectURIs:
      - "https://{{ domnain_netbird }}/nb-auth"
      - "https://{{ domnain_netbird }}/nb-silent-auth"
    cliRedirectURIs:
      - "http://localhost:53000/"

  reverseProxy:
    trustedHTTPProxies:
      - "172.30.0.10/32"

  store:
{% if use_postgres_on_netbird %}
    engine: "postgres"
    encryptionKey: "{{ random_key_2 }}"  # 32-byte (256-bit) encryption key
    dsn: "host={{ postgres_db_netbird.container_name }} user={{ postgres_db_netbird.postgres_db_username }} password={{ postgres_db_netbird.postgres_db_password }} dbname={{ postgres_db_netbird.netbird_store_db_name }} sslmode=disable port={{ postgres_db_netbird.postgreS_db_port }}"
{% else %}
    engine: "sqlite"
    encryptionKey: "{{ random_key_2 }}"  # 32-byte (256-bit) encryption key
{% endif %}

{% if use_postgres_on_netbird %}
  activityStore:
    engine: "postgres"
    dsn: "host={{ postgres_db_netbird.container_name }} user={{ postgres_db_netbird.postgres_db_username }} password={{ postgres_db_netbird.postgres_db_password }} dbname={{ postgres_db_netbird.netbird_events_db_name }} sslmode=disable port={{ postgres_db_netbird.postgreS_db_port }}"
{% endif %}
