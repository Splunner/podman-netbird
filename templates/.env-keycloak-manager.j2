# .env
# Keycloak admin
KEYCLOAK_ADMIN={{keycloak_manager.keycloak_admin}}
KEYCLOAK_ADMIN_PASSWORD={{keycloak_manager.keycloak_admin_password}}

# HTTP ENABLE
KC_HTTP_ENABLED={{keycloak_manager.kc_http_enabled}}

# Disable hostanme check
KC_HOSTNAME_STRICT={{keycloak_manager.kc_hostname_strict}}

# reverse proxy
KC_PROXY_HEADERS={{keycloak_manager.kc_forward_proxy_value}}
KC_HTTP_RELATIVE_PATH={{keycloak_manager.kc_http_relative_path_value}}
# Database config
KC_DB={{postgres_db.postgres_db_name}}
KC_DB_URL_HOST={{postgres_db.container_name}}
KC_DB_USERNAME={{postgres_db.postgres_db_name}}
# might be updated before start using it.
KC_DB_PASSWORD={{postgres_db.postgres_db_password}}

