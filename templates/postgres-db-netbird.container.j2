[Unit]
Description={{postgres_db_netbird.description}}
After=network-online.target
Wants=network-online.target

[Container]
Image={{postgres_db_netbird.image}}
Network={{postgres_db_netbird.network}}

EnvironmentFile={{postgres_db_netbird.env_file}}
Environment=PGDATA=/var/lib/postgresql/data/data

{% for volume  in postgres_db_netbird.volumes %}
{% set Volume = volume %}
Volume={{ Volume }}
{% endfor %}


{% for port in postgres_db_netbird.ports %}
{% set PublishPort = port %}
PublishPort={{ PublishPort }}
{% endfor %}

ContainerName={{postgres_db_netbird.container_name}}

HealthCmd=pg_isready -U {{postgres_db_netbird.postgres_db_username}}
HealthInterval=10s
HealthTimeout=5s
HealthRetries=5
HealthStartPeriod=20s

[Service]
Restart=on-failure
TimeoutStartSec=180
TimeoutStopSec=60

[Install]
WantedBy=default.target